{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "python",
  "exclude-paths": [
    ".github",
    "demo",
    "docs",
    "tests"
  ],
  "packages": {
    ".": {}
  },
  "extra-files": [
    {
      "path": "uv.lock",
      "type": "toml",
      "jsonpath": "$.package[?(@.name.value=='evalwire')].version"
    }
  ]
}