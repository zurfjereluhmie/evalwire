# Copy this file to .env and fill in your values.
#   cp demo/.env.example demo/.env

# Required — OpenAI API key used by the RAG pipeline's generate node.
OPENAI_API_KEY=sk-...

# Base URL of the self-hosted Phoenix instance (Docker Compose default).
PHOENIX_BASE_URL=http://localhost:6006

# Optional — only required when Phoenix is started with authentication enabled.
# PHOENIX_API_KEY=
